# WeRead2Notion v0.2 Configuration
# Copy this file to .env and fill in your values

# WeRead Gateway API Key
# Get from: https://weread.qq.com -> Settings -> API
WEREAD_API_KEY=your_weread_api_key

# Notion Integration Token
# Create at: https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_token

# Parent Page ID (where the library will be created)
# Create a page in Notion, connect your integration to it, then paste the page ID
NOTION_PAGE=your_parent_page_id
