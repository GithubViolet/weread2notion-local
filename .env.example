# ============================================================
# WeRead2Notion 配置文件
# 复制本文件为 .env，填入你的密钥后保存
# ============================================================

# 微信读书 API Key（从浏览器开发者工具获取，以 wrk- 开头）
WEREAD_API_KEY=wrk-你的APIKey

# Notion Integration Token（从 notion.so/my-integrations 获取）
NOTION_TOKEN=ntn_你的Token

# Notion 页面链接或页面 ID（用于存放书籍的父页面）
NOTION_PAGE=https://www.notion.so/你的页面链接
